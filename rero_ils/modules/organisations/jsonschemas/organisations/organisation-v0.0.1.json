{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Organisation",
  "description": "Usually a network of several libraries sharing data for patrons, items, etc.",
  "additionalProperties": false,
  "propertiesOrder": [
    "name",
    "address",
    "default_currency",
    "homepage",
    "patron_cleanup"
  ],
  "required": [
    "name",
    "default_currency"
  ],
  "properties": {
    "$schema": {
      "title": "Schema",
      "type": "string",
      "minLength": 9,
      "default": "https://bib.rero.ch/schemas/organisations/organisation-v0.0.1.json"
    },
    "pid": {
      "title": "Organisation ID",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "description": "Name of the organisation.",
      "type": "string",
      "minLength": 1
    },
    "address": {
      "title": "Address",
      "description": "Address of the organisation.",
      "type": "string",
      "minLength": 1
    },
    "code": {
      "title": "Code",
      "description": "Code of the organisation.",
      "type": "string",
      "minLength": 2
    },
    "current_budget_pid": {
      "title": "Current ID of the budget",
      "description": "The ID of the current budget of the organisation",
      "type": "string"
    },
    "default_currency": {
      "title": "Default currency",
      "description": "The default currency of the organisation",
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "online_harvested_source": {
      "title": "Online harvested sources",
      "description": "Online harvested sources as configured in ebooks server.",
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "collection_enabled_on_public_view": {
      "title": "Collection enabled on public view",
      "type": "boolean",
      "default": false
    },
    "patron_cleanup": {
      "title": "Patron cleanup configuration",
      "description": "Configuration for the automatic deletion of inactive patron profiles. Delete the field if you never want the patrons to be deleted automatically.",
      "type": "object",
      "additionalProperties": false,
      "propertiesOrder": [
        "expiration_years",
        "inactivity_years",
        "excluded_patron_types"
      ],
      "required": [
        "expiration_years",
        "inactivity_years"
      ],
      "properties": {
        "expiration_years": {
          "title": "Expiration threshold (years)",
          "description": "Only delete patrons whose expiration_date is older than this many years ago.",
          "type": "integer",
          "minimum": 1
        },
        "inactivity_years": {
          "title": "Inactivity threshold (years)",
          "description": "Only delete patrons whose user last logged in more than this many years ago.",
          "type": "integer",
          "minimum": 1
        },
        "excluded_patron_types": {
          "title": "Excluded patron types",
          "description": "List of patron type PIDs to exclude from automatic deletion.",
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "widget": {
        "formlyConfig": {
          "props": {
            "hide": true,
            "navigation": {
              "essential": true
            }
          }
        }
      }
    },
    "homepage": {
      "title": "Homepage",
      "type": "object",
      "description": "Configuration for the public homepage.",
      "additionalProperties": false,
      "propertiesOrder": [
        "slogan",
        "placeholder",
        "blocks"
      ],
      "properties": {
        "slogan": {
          "title": "Slogan",
          "type": "array",
          "description": "Text displayed on the public homepage banner.",
          "minItems": 0,
          "items": {
            "type": "object",
            "title": "Slogan",
            "additionalProperties": false,
            "required": [
              "language",
              "value"
            ],
            "propertiesOrder": [
              "language",
              "value"
            ],
            "properties": {
              "language": {
                "$ref": "https://bib.rero.ch/schemas/common/ui-languages-v0.0.1.json#/language"
              },
              "value": {
                "title": "value",
                "type": "string",
                "maxLength": 255,
                "minLength": 1,
                "widget": {
                  "formlyConfig": {
                    "props": {
                      "itemCssClass": "ui:col-span-12 ui:md:col-span-9"
                    }
                  }
                }
              }
            },
            "widget": {
              "formlyConfig": {
                "props": {
                  "containerCssClass": "ui:grid ui:grid-cols-12 ui:gap-2"
                }
              }
            }
          },
          "widget": {
            "formlyConfig": {
              "props": {
                "validation": {
                  "validators": {
                    "uniqueValueKeysInObject": {
                      "keys": [
                        "language"
                      ]
                    }
                  },
                  "messages": {
                    "uniqueValueKeysInObjectMessage": "Only one value per language is allowed."
                  }
                }
              }
            }
          }
        },
        "placeholder": {
          "title": "Placeholder",
          "type": "array",
          "description": "Placeholder text displayed in the public homepage search box.",
          "minItems": 0,
          "items": {
            "type": "object",
            "title": "Placeholder",
            "additionalProperties": false,
            "required": [
              "language",
              "value"
            ],
            "propertiesOrder": [
              "language",
              "value"
            ],
            "properties": {
              "language": {
                "$ref": "https://bib.rero.ch/schemas/common/ui-languages-v0.0.1.json#/language"
              },
              "value": {
                "title": "value",
                "type": "string",
                "maxLength": 255,
                "minLength": 1,
                "widget": {
                  "formlyConfig": {
                    "props": {
                      "itemCssClass": "ui:col-span-12 ui:md:col-span-9"
                    }
                  }
                }
              }
            },
            "widget": {
              "formlyConfig": {
                "props": {
                  "containerCssClass": "ui:grid ui:grid-cols-12 ui:gap-2"
                }
              }
            }
          },
          "widget": {
            "formlyConfig": {
              "props": {
                "validation": {
                  "validators": {
                    "uniqueValueKeysInObject": {
                      "keys": [
                        "language"
                      ]
                    }
                  },
                  "messages": {
                    "uniqueValueKeysInObjectMessage": "Only one value per language is allowed."
                  }
                }
              }
            }
          }
        },
        "blocks": {
          "title": "Blocks",
          "type": "object",
          "description": "HTML content displayed in the homepage blocks.",
          "additionalProperties": false,
          "propertiesOrder": [
            "left",
            "center",
            "right"
          ],
          "properties": {
            "left": {
              "title": "Left block",
              "type": "array",
              "description": "HTML content displayed in the left homepage block. Will also be the first block displayed on mobile.",
              "minItems": 0,
              "items": {
                "type": "object",
                "title": "Left block",
                "additionalProperties": false,
                "required": [
                  "language",
                  "value"
                ],
                "propertiesOrder": [
                  "language",
                  "value"
                ],
                "properties": {
                  "language": {
                    "$ref": "https://bib.rero.ch/schemas/common/ui-languages-v0.0.1.json#/language"
                  },
                  "value": {
                    "title": "HTML",
                    "type": "string",
                    "minLength": 1,
                    "widget": {
                      "formlyConfig": {
                        "type": "textarea",
                        "props": {
                          "rows": 8,
                          "itemCssClass": "ui:col-span-12 ui:md:col-span-9"
                        }
                      }
                    }
                  }
                },
                "widget": {
                  "formlyConfig": {
                    "props": {
                      "containerCssClass": "ui:grid ui:grid-cols-12 ui:gap-2"
                    }
                  }
                }
              },
              "widget": {
                "formlyConfig": {
                  "props": {
                    "validation": {
                      "validators": {
                        "uniqueValueKeysInObject": {
                          "keys": [
                            "language"
                          ]
                        }
                      },
                      "messages": {
                        "uniqueValueKeysInObjectMessage": "Only one value per language is allowed."
                      }
                    }
                  }
                }
              }
            },
            "center": {
              "title": "Center block",
              "type": "array",
              "description": "HTML content displayed in the center homepage block. Will also be the second block displayed on mobile.",
              "minItems": 0,
              "items": {
                "type": "object",
                "title": "Center block",
                "additionalProperties": false,
                "required": [
                  "language",
                  "value"
                ],
                "propertiesOrder": [
                  "language",
                  "value"
                ],
                "properties": {
                  "language": {
                    "$ref": "https://bib.rero.ch/schemas/common/ui-languages-v0.0.1.json#/language"
                  },
                  "value": {
                    "title": "HTML",
                    "type": "string",
                    "minLength": 1,
                    "widget": {
                      "formlyConfig": {
                        "type": "textarea",
                        "props": {
                          "rows": 8,
                          "itemCssClass": "ui:col-span-12 ui:md:col-span-9"
                        }
                      }
                    }
                  }
                },
                "widget": {
                  "formlyConfig": {
                    "props": {
                      "containerCssClass": "ui:grid ui:grid-cols-12 ui:gap-2"
                    }
                  }
                }
              },
              "widget": {
                "formlyConfig": {
                  "props": {
                    "validation": {
                      "validators": {
                        "uniqueValueKeysInObject": {
                          "keys": [
                            "language"
                          ]
                        }
                      },
                      "messages": {
                        "uniqueValueKeysInObjectMessage": "Only one value per language is allowed."
                      }
                    }
                  }
                }
              }
            },
            "right": {
              "title": "Right block",
              "type": "array",
              "description": "HTML content displayed in the right homepage block. Will also be the third block displayed on mobile.",
              "minItems": 0,
              "items": {
                "type": "object",
                "title": "Right block",
                "additionalProperties": false,
                "required": [
                  "language",
                  "value"
                ],
                "propertiesOrder": [
                  "language",
                  "value"
                ],
                "properties": {
                  "language": {
                    "$ref": "https://bib.rero.ch/schemas/common/ui-languages-v0.0.1.json#/language"
                  },
                  "value": {
                    "title": "HTML",
                    "type": "string",
                    "minLength": 1,
                    "widget": {
                      "formlyConfig": {
                        "type": "textarea",
                        "props": {
                          "rows": 8,
                          "itemCssClass": "ui:col-span-12 ui:md:col-span-9"
                        }
                      }
                    }
                  }
                },
                "widget": {
                  "formlyConfig": {
                    "props": {
                      "containerCssClass": "ui:grid ui:grid-cols-12 ui:gap-2"
                    }
                  }
                }
              },
              "widget": {
                "formlyConfig": {
                  "props": {
                    "validation": {
                      "validators": {
                        "uniqueValueKeysInObject": {
                          "keys": [
                            "language"
                          ]
                        }
                      },
                      "messages": {
                        "uniqueValueKeysInObjectMessage": "Only one value per language is allowed."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
